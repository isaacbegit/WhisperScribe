<UserControl x:Class="WhisperScribe.Views.ConvertedView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Converted Library" Style="{StaticResource Text.H1}" />
                <TextBlock Text="Every file WhisperScribe has transcribed, stored locally in SQLite" Style="{StaticResource Text.Body}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBox Width="240" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Tag="Search by file name or language…" Margin="0,0,10,0" />
                <Button Content="⟳ Refresh" Style="{StaticResource Button.Secondary}" Command="{Binding RefreshCommand}" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource Panel.Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.4*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <DataGrid Grid.Column="0" ItemsSource="{Binding Records}" SelectedItem="{Binding SelectedRecord}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="FILE NAME" Binding="{Binding FileName}" Width="1.8*" />
                        <DataGridTextColumn Header="LANGUAGE" Binding="{Binding Language}" Width="0.8*" />
                        <DataGridTextColumn Header="MODEL" Binding="{Binding ModelUsed}" Width="1*" />
                        <DataGridTextColumn Header="HARDWARE" Binding="{Binding HardwareUsed}" Width="1.2*" />
                        <DataGridTextColumn Header="DURATION" Binding="{Binding DurationSeconds, Converter={StaticResource SecondsToDuration}}" Width="0.8*" />
                        <DataGridTextColumn Header="DATE" Binding="{Binding CreatedAtUtc, StringFormat='{}{0:MMM d, yyyy HH:mm}'}" Width="1.1*" />
                        <DataGridTemplateColumn Header="" Width="40">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="✕" Style="{StaticResource Button.Icon}" Width="26" Height="26" FontSize="10"
                                            Command="{Binding DataContext.DeleteRecordCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Detail panel for the selected record -->
                <Border Grid.Column="2" Background="{StaticResource Brush.Surface}" CornerRadius="10" Padding="16"
                        Visibility="{Binding SelectedRecord, Converter={StaticResource NullToVis}}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="{Binding SelectedRecord.FileName}" Style="{StaticResource Text.H2}" Margin="0,0,0,10" />
                        <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                            <Button Content="⭳ Export Text" Style="{StaticResource Button.Danger}" Margin="0,0,0,10" Height="46" FontSize="14"
                                    Command="{Binding ExportTextCommand}" CommandParameter="{Binding SelectedRecord}" />
                            <Button Content="⭳ Export SRT" Style="{StaticResource Button.Danger}" Margin="0,0,0,10" Height="46" FontSize="14"
                                    Command="{Binding ExportSrtCommand}" CommandParameter="{Binding SelectedRecord}" />
                            <Button Content="⭳ Export JSON" Style="{StaticResource Button.Danger}" Height="46" FontSize="14"
                                    Command="{Binding ExportJsonCommand}" CommandParameter="{Binding SelectedRecord}" />
                        </StackPanel>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding SelectedRecord.PlainText}" TextWrapping="Wrap"
                                       Foreground="{StaticResource Brush.TextSecondary}" FontSize="12.5" LineHeight="20" />
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
