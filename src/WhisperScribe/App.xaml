<Application x:Class="WhisperScribe.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WhisperScribe.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/ColorPalette.xaml" />
                <ResourceDictionary Source="Themes/ControlStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
            <conv:BoolToVisibilityConverter x:Key="InverseBoolToVis" Invert="True" />
            <conv:NullToVisibilityConverter x:Key="NullToVis" />
            <conv:StatusToBrushConverter x:Key="StatusToBrush" />
            <conv:InverseBooleanConverter x:Key="InverseBool" />
            <conv:SecondsToDurationConverter x:Key="SecondsToDuration" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
