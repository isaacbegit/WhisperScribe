<UserControl x:Class="WhisperScribe.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Settings" Style="{StaticResource Text.H1}" />
            <TextBlock Text="Download the Whisper models you need. Models run fully offline once downloaded." Style="{StaticResource Text.Body}" />
        </StackPanel>

        <!-- ===================== Models download path ===================== -->
        <Border Grid.Row="2" Style="{StaticResource Panel.Card}">
            <StackPanel>
                <TextBlock Text="Models Download Path" Style="{StaticResource Text.H2}" Margin="0,0,0,4" />
                <TextBlock Text="All models are stored under this folder, each in its own subfolder (e.g. …\Models\base.en\)."
                           Style="{StaticResource Text.Caption}" Margin="0,0,0,14" TextWrapping="Wrap" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" Text="{Binding ModelsRootPath, Mode=OneWay}" IsReadOnly="True" VerticalContentAlignment="Center" />

                    <Button Grid.Column="2" Content="Browse…" Style="{StaticResource Button.Secondary}"
                            Height="40" MinWidth="130" Command="{Binding BrowseModelsFolderCommand}" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- ===================== Whisper model catalog ===================== -->
        <Border Grid.Row="4" Style="{StaticResource Panel.Card}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Whisper Models" Style="{StaticResource Text.H2}" Margin="0,0,0,14" />

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Models}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource Brush.Surface}" CornerRadius="10" Padding="16" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="180" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DisplayName}" Style="{StaticResource Text.H2}" FontSize="14" />
                                            <Border Background="{StaticResource Brush.Success}" CornerRadius="10" Padding="8,2" Margin="10,0,0,0"
                                                    Visibility="{Binding IsDownloaded, Converter={StaticResource BoolToVis}}" VerticalAlignment="Center">
                                                <TextBlock Text="DOWNLOADED" FontSize="9" FontFamily="Segoe UI Semibold" Foreground="#08210F" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Description}" Style="{StaticResource Text.Caption}" Margin="0,4,0,0" TextWrapping="Wrap" />
                                    </StackPanel>

                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SizeDisplay}" Style="{StaticResource Text.Body}" VerticalAlignment="Center" HorizontalAlignment="Center" />

                                    <Grid Grid.Row="0" Grid.Column="2" VerticalAlignment="Center">
                                        <Button Content="Download" Style="{StaticResource Button.Primary}"
                                                Height="48" MinWidth="130" FontSize="14"
                                                Command="{Binding DataContext.DownloadModelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Visibility="{Binding IsDownloaded, Converter={StaticResource InverseBoolToVis}}" />
                                        <Button Content="Remove" Style="{StaticResource Button.Secondary}"
                                                Command="{Binding DataContext.DeleteModelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Visibility="{Binding IsDownloaded, Converter={StaticResource BoolToVis}}" />
                                    </Grid>

                                    <!-- Download progress: small height, spans the full row width -->
                                    <ProgressBar Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                                 Value="{Binding DownloadProgress, Mode=OneWay}" Minimum="0" Maximum="100"
                                                 Height="5" Margin="0,10,0,0"
                                                 Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
